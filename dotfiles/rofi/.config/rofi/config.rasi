configuration {
    modi: "drun,run,window";
    show-icons: true;
    terminal: "kitty";
    drun-display-format: "{name}";
    location: 0;
    disable-history: false;
    hide-scrollbar: true;
    display-drun: "   Apps";
    display-run: "   Run";
    display-window: " Window";
    sidebar-mode: true;
}

@theme "~/.config/rofi/theme.rasi"
